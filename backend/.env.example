# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Database (Railway MySQL) ──────────────────────────────────────────────────
# Railway genera estas variables automáticamente al agregar el plugin de MySQL.
# Cópialas desde: Railway dashboard → MySQL service → Variables
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# ─── Dominio ───────────────────────────────────────────────────────────────────
# Dominio base sin subdominio. Ej: stylio.cl
TENANT_BASE_DOMAIN=stylio.cl

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

# ─── Google Calendar (opcional) ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://tuapp.up.railway.app/api/integrations/google/callback
GOOGLE_WEBHOOK_URL=

# ─── Polar (billing, opcional) ────────────────────────────────────────────────
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_ID=
POLAR_SUCCESS_URL=
POLAR_SANDBOX=false
